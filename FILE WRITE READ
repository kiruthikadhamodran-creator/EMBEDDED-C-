#include<stdio.h>
#include<fcntl.h> 
#include<unistd.h>
int main(){
     int fd; 
     char buf[50];
     fd = open("myfile.txt", O_CREAT | O_RDWR);
     write(fd,"Welcome of File handling Emb. Linux",36);
     lseek(fd, 0, SEEK_SET);
     read(fd,buf,36);
     printf("\nFile Contents:%s",buf);
     chmod("myfile.txt",0644);
     close(fd);
     return 0;
}
